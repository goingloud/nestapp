# Ignore everything by default
*
*/

# Explicitly track these files
!.gitignore
!LICENSE
!README.md
!run_nestapp.m

# Source files
!src/
!src/*.m
!src/*.png
!src/*.jpg
!src/templates/
!src/templates/*.mat

# Tests (develop branch only)
!tests/
!tests/unit/
!tests/unit/*.m
!tests/integration/
!tests/integration/*.m
!tests/regression/
!tests/regression/*.m
!tests/*.m
